#!/bin/bash

LOG_FILE="${TRIM_PKGVAR}/info.log"
PID_FILE="${TRIM_PKGVAR}/app.pid"

NODE_BIN="${TRIM_APPDEST}/server/node-runtime/bin/node"
OPENCLAW_ENTRY="${TRIM_APPDEST}/server/openclaw-bundle/dist/index.js"
CFG_DIR="${TRIM_PKGVAR}/.openclaw"
CFG_FILE="${CFG_DIR}/openclaw.json"

log_msg() {
  echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >>"${LOG_FILE}"
}

check_process() {
  local pid="$1"
  kill -0 "${pid}" 2>/dev/null
}

status() {
  if [ -f "${PID_FILE}" ]; then
    pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
    if check_process "${pid}"; then
      return 0
    fi
    rm -f "${PID_FILE}"
  fi
  return 1
}

start_process() {
  if status; then
    return 0
  fi

  [ -x "${NODE_BIN}" ] || { log_msg "node runtime missing"; return 1; }
  [ -f "${OPENCLAW_ENTRY}" ] || { log_msg "openclaw entry missing"; return 1; }
  mkdir -p "${CFG_DIR}" "${TRIM_PKGVAR}"
  [ -f "${CFG_FILE}" ] || cp -f "${TRIM_APPDEST}/server/config/openclaw.template.json" "${CFG_FILE}" 2>/dev/null || true

  log_msg "Starting OpenClaw gateway ..."
  (
    export OPENCLAW_STATE_DIR="${CFG_DIR}"
    export OPENCLAW_CONFIG_PATH="${CFG_FILE}"
    export HOME="${TRIM_PKGVAR}"
    exec "${NODE_BIN}" "${OPENCLAW_ENTRY}" gateway run --allow-unconfigured
  ) >>"${LOG_FILE}" 2>&1 &

  printf "%s" "$!" >"${PID_FILE}"
  return 0
}

stop_process() {
  log_msg "Stopping OpenClaw gateway ..."
  if [ -r "${PID_FILE}" ]; then
    pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
    if check_process "${pid}"; then
      kill -TERM "${pid}" >>"${LOG_FILE}" 2>&1 || true
      for _ in $(seq 1 10); do
        check_process "${pid}" || break
        sleep 1
      done
      if check_process "${pid}"; then
        kill -KILL "${pid}" >>"${LOG_FILE}" 2>&1 || true
      fi
    fi
    rm -f "${PID_FILE}"
  fi
  return 0
}

case "$1" in
  start)
    start_process
    ;;
  stop)
    stop_process
    ;;
  status)
    if status; then
      exit 0
    else
      exit 3
    fi
    ;;
  *)
    exit 1
    ;;
esac
