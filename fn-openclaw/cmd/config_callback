#!/bin/bash

set -e

CFG_FILE="${TRIM_PKGVAR}/.openclaw/openclaw.json"
WIZARD_ENV="${TRIM_PKGVAR}/wizard.env"
NODE_BIN="${TRIM_APPDEST}/server/node-runtime/bin/node"

mkdir -p "${TRIM_PKGVAR}"
cat >"${WIZARD_ENV}" <<ENV
WIZARD_PORT=${wizard_port}
WIZARD_TOKEN=${wizard_token}
WIZARD_BASE_URL=${wizard_base_url}
WIZARD_API_KEY=${wizard_api_key}
ENV

[ -x "${NODE_BIN}" ] || exit 0
[ -f "${CFG_FILE}" ] || exit 0

"${NODE_BIN}" -e '
const fs = require("fs");
const cfgPath = process.argv[1];
const envPath = process.argv[2];
const cfg = JSON.parse(fs.readFileSync(cfgPath, "utf8"));
const env = Object.fromEntries(fs.readFileSync(envPath, "utf8").split(/\n+/).filter(Boolean).map(l=>l.split("=")).filter(a=>a.length>=2).map(([k,...v])=>[k,v.join("=")]));
const trim = (v) => typeof v === "string" ? v.trim() : "";
const portRaw = trim(env.WIZARD_PORT);
const token = trim(env.WIZARD_TOKEN);
const baseUrl = trim(env.WIZARD_BASE_URL);
const apiKey = trim(env.WIZARD_API_KEY);
cfg.gateway = cfg.gateway || {};
if (portRaw) {
  const port = Number(portRaw);
  if (Number.isFinite(port)) cfg.gateway.port = port;
}
cfg.gateway.auth = cfg.gateway.auth || {};
if (token) {
  cfg.gateway.auth.mode = "token";
  cfg.gateway.auth.token = token;
}
cfg.models = cfg.models || {};
cfg.models.providers = cfg.models.providers || {};
cfg.models.providers.default = cfg.models.providers.default || {};
if (baseUrl) cfg.models.providers.default.baseUrl = baseUrl;
if (apiKey) cfg.models.providers.default.apiKey = apiKey;
fs.writeFileSync(cfgPath, JSON.stringify(cfg, null, 2) + "\n", "utf8");
' "${CFG_FILE}" "${WIZARD_ENV}" || exit 1

exit 0
