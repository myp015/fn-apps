#!/bin/bash

set -e

ARCH=$(uname -m)
SERVER_DIR="${TRIM_APPDEST}/server"
ARCH_DIR="${SERVER_DIR}/${ARCH}"
NODE_DIR="${SERVER_DIR}/node-runtime"
BUNDLE_DIR="${SERVER_DIR}/openclaw-bundle"
CFG_DIR="${TRIM_PKGVAR}/.openclaw"
CFG_FILE="${CFG_DIR}/openclaw.json"
WIZARD_ENV="${TRIM_PKGVAR}/wizard.env"

if [ ! -d "${ARCH_DIR}" ]; then
  echo "openclaw runtime for ${ARCH} not found" >"${TRIM_TEMP_LOGFILE}"
  exit 1
fi

mkdir -p "${SERVER_DIR}" "${CFG_DIR}"

# Save wizard values for runtime/config updates.
cat >"${WIZARD_ENV}" <<ENV
WIZARD_PORT=${wizard_port:-18789}
WIZARD_TOKEN=${wizard_token:-123456}
WIZARD_BASE_URL=${wizard_base_url:-http://127.0.0.1:8317/v1}
WIZARD_API_KEY=${wizard_api_key:-sk-V5zPkG6MJrIpxgmDw}
ENV

# Activate arch runtime bundle.
rm -rf "${NODE_DIR}" "${BUNDLE_DIR}"
cp -a "${ARCH_DIR}/node-runtime" "${NODE_DIR}" || {
  echo "copy node runtime failed" >"${TRIM_TEMP_LOGFILE}"
  exit 1
}
cp -a "${ARCH_DIR}/openclaw-bundle" "${BUNDLE_DIR}" || {
  echo "copy openclaw bundle failed" >"${TRIM_TEMP_LOGFILE}"
  exit 1
}

# Initialize config if missing.
if [ ! -f "${CFG_FILE}" ]; then
  cp -f "${TRIM_APPDEST}/server/config/openclaw.template.json" "${CFG_FILE}" 2>>"${TRIM_TEMP_LOGFILE}" || {
    echo "initialize openclaw config failed" >"${TRIM_TEMP_LOGFILE}"
    exit 1
  }
fi

# Apply wizard values into config.
"${NODE_DIR}/bin/node" -e '
const fs = require("fs");
const cfgPath = process.argv[1];
const envPath = process.argv[2];
const cfg = JSON.parse(fs.readFileSync(cfgPath, "utf8"));
const env = Object.fromEntries(fs.readFileSync(envPath, "utf8").split(/\n+/).filter(Boolean).map(l=>l.split("=")).filter(a=>a.length>=2).map(([k,...v])=>[k,v.join("=")]));
const port = Number(env.WIZARD_PORT || 18789);
const token = env.WIZARD_TOKEN || "123456";
const baseUrl = env.WIZARD_BASE_URL || "http://127.0.0.1:8317/v1";
const apiKey = env.WIZARD_API_KEY || "sk-V5zPkG6MJrIpxgmDw";
cfg.gateway = cfg.gateway || {};
cfg.gateway.port = Number.isFinite(port) ? port : 18789;
cfg.gateway.auth = cfg.gateway.auth || {};
cfg.gateway.auth.mode = "token";
cfg.gateway.auth.token = token;
cfg.models = cfg.models || {};
cfg.models.providers = cfg.models.providers || {};
cfg.models.providers.default = cfg.models.providers.default || {};
cfg.models.providers.default.baseUrl = baseUrl;
cfg.models.providers.default.apiKey = apiKey;
fs.writeFileSync(cfgPath, JSON.stringify(cfg, null, 2) + "\n", "utf8");
' "${CFG_FILE}" "${WIZARD_ENV}" >>"${TRIM_TEMP_LOGFILE}" 2>&1 || {
  echo "apply wizard config failed" >"${TRIM_TEMP_LOGFILE}"
  exit 1
}

exit 0
